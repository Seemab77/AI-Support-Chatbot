# Server Configuration
PORT=5000
NODE_ENV=development

# NLP Service Selection (choose one):
# 1. For Gemini API (recommended - free tier available)
GEMINI_API_KEY=your-gemini-api-key

# 2. For OpenAI GPT API (requires OpenAI account)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# 3. For Dialogflow (requires Google Cloud Project)
DIALOGFLOW_PROJECT_ID=your-google-cloud-project-id
DIALOGFLOW_PRIVATE_KEY_ID=your-private-key-id
DIALOGFLOW_PRIVATE_KEY=your-private-key
DIALOGFLOW_CLIENT_EMAIL=your-client-email
DIALOGFLOW_CLIENT_ID=your-client-id
DIALOGFLOW_AUTH_URI=https://accounts.google.com/o/oauth2/auth
DIALOGFLOW_TOKEN_URI=https://oauth2.googleapis.com/token
DIALOGFLOW_LANGUAGE_CODE=en-US

# Database Configuration (Optional)
MONGODB_URI=mongodb://localhost:27017/ai-chatbot
# Or for Firebase:
# FIREBASE_API_KEY=your-firebase-key
# FIREBASE_AUTH_DOMAIN=your-auth-domain
# FIREBASE_PROJECT_ID=your-project-id

# Client Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Session Configuration
SESSION_SECRET=your-secret-key
CORS_ORIGIN=http://localhost:3000
